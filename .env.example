# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Telegram Bot Token — from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# OpenRouter API Key — https://openrouter.ai (free tier available)
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXX

# ── LLM MODELS (optional, defaults are fine) ──────────────────────────────────
# LLM_MODEL=openai/gpt-4o-mini
# LLM_SMART_MODEL=openai/gpt-4o
# EMBEDDING_MODEL=openai/text-embedding-3-small

# ── TON INTEGRATION ───────────────────────────────────────────────────────────

# 24-word mnemonic — the bot wallet that signs NFT mint transactions
# Create a testnet wallet: Tonkeeper → Settings → tap version 5x → Testnet
TON_MNEMONIC=word1 word2 word3 ... word24

# testnet or mainnet
TON_NETWORK=testnet

# TonCenter API key (optional, raises rate limits) — https://toncenter.com
# TON_API_KEY=

# GitHub Personal Access Token — used to upload NFT metadata JSON to the repo
# Create at: https://github.com/settings/tokens → repo scope
GITHUB_TOKEN=YOUR_GITHUB_PAT_HERE
